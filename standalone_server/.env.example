# Database Configuration
DEVICE_MANAGER_DB_HOST=192.168.1.160
DEVICE_MANAGER_DB_PORT=3306
DEVICE_MANAGER_DB_NAME=ecologic
DEVICE_MANAGER_DB_USER=ecouser
DEVICE_MANAGER_DB_PASSWORD=ecopass

# Basic Authentication (fallback)
BASIC_USER=admin
BASIC_PASS=admin123

# InfluxDB Configuration
INFLUXDB_TOKEN=your_influxdb_token_here
INFLUXDB_ORG=ecologic
INFLUXDB_BUCKET=default
INFLUXDB_HOST=192.168.1.160
INFLUXDB_PORT=8086

# Grafana Configuration
GRAFANA_HOST=192.168.1.160
GRAFANA_PORT=3000
GRAFANA_ADMIN_USER=admin
GRAFANA_ADMIN_PASSWORD=admin

# Note: INFLUXDB_HOST can be different from DB_HOST in Docker environments
# DB_HOST is for MySQL, INFLUXDB_HOST is for InfluxDB
# To get your InfluxDB token:
# 1. Go to http://192.168.1.160:8086
# 2. Login with admin/adminpass
# 3. Go to Load Data -> API Tokens
# 4. Generate new token with read/write access to 'default' bucket
# 5. Replace 'your_influxdb_token_here' with the generated token